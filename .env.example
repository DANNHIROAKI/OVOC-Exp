# Required: shared Ark / Volcengine API key.
OV_OC_ARK_API_KEY=replace-me

# Required: OpenClaw generator endpoint.
OV_OC_OPENCLAW_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OV_OC_OPENCLAW_MODEL_ID=replace-with-your-seed-2.0-code-endpoint-id

# Required: OpenViking VLM + embedding endpoints used inside ov.conf.
OV_OC_OV_VLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
OV_OC_OV_VLM_MODEL=replace-with-your-openviking-vlm-endpoint-id
OV_OC_OV_EMBED_API_BASE=https://ark.cn-beijing.volces.com/api/v3
OV_OC_OV_EMBED_MODEL=replace-with-your-openviking-embedding-endpoint-id

# Required: judge model.
OV_OC_JUDGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OV_OC_JUDGE_MODEL=replace-with-your-judge-model-or-endpoint-id

# Optional: generated automatically if omitted.
OPENCLAW_GATEWAY_TOKEN=
OPENVIKING_API_KEY=

# Optional execution switches.
OV_OC_RERUNS=1
OV_OC_STRICT_OV_USAGE=1
OV_OC_FORCE_EXPLICIT_COMMIT_FOR_OV_TELEMETRY=0
OV_OC_RUN_OV_SMOKE=1
